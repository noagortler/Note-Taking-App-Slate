<%- include('partials/header') %>

    <main>
        <div class="dashboard-container">

            <!-- create note form -->
            <div class="create-note">
                <h2>Add to your slate</h2>

                <% if (error) { %>
                <div class="error-message">
                    <%= error %>
                </div>
                <% } %>

                <form action="/notes" method="POST">

                    <div class="form-group">
                        <label for="title">Title</label>
                        <input type="text" id="title" name="title" placeholder="Title" required>
                    </div>

                    <div class="form-group">
                        <label for="category">Category</label>
                        <select id="category" name="category" required>
                            <option value="">Select a category</option>
                            <option value="Notes">Notes</option>
                            <option value="To-Do">To-Do</option>
                            <option value="List">List</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="content">Content</label>
                        <textarea id="content" name="content" placeholder="Start writing" required></textarea>
                    </div>

                    <button type="submit">Done</button>
                </form>
            </div>

            <!-- notes grid -->
            <div class="notes-grid">
                <h2>Your Slate</h2>

                <!-- category filter -->
                <div class="category-filter">
                    <span>Filter by:</span>
                    <a href="/notes">All</a>
                    <a href="/notes?category=Notes">Notes</a>
                    <a href="/notes?category=To-Do">To-Do</a>
                    <a href="/notes?category=List">List</a>
                </div>

                <% if (notes.length === 0) { %>
                    <p>A clean slate. Start writing!</p>

                <% } else { %>
                    <div class="notes-cards">
                        <% notes.forEach(note => { %>

                            <a href="/notes/<%= note._id %>" class="note-card-link">
                                <div class="note-card <%= note.category.toLowerCase().replace('-', '') %>">
                                    <div class="note-card-header">
                                        <span class="note-category"><%= note.category %></span>
                                        <span class="note-date"><%= note.createdAt %></span>
                                    </div>
                                    <h3><%= note.title %></h3>
                                    <p><%= note.content %></p>
                                </div>
                            </a>

                            <div class="note-card-actions">
                                        <button class="edit-btn" id="<%= note.id %>">Edit</button>
                                        <button class="delete-btn" id="<%= note.id %>">Delete</button>
                            </div>

                        <% }) %>
                    </div>
                <% } %>

            </div>

        </div>

    </main>

<%- include('partials/footer') %>