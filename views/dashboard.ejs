<%- include('partials/header') %>

    <main>
        <div class="dashboard-container">

            <!-- create note form -->
            <div class="create-note">
                <h2 class="dashboard-title">Add to your Slate</h2>

                <form action="/notes" method="POST" class="create-note-form">

                    <div class="form-header">

                        <% if (error) { %>
                        <div class="error-message">
                            <%= error %>
                        </div>
                        <% } %>

                        <input type="text" name="title" placeholder="Title" required>

                        <select name="category" required>
                            <option value="">Select a category</option>
                            <option value="Notes">Notes</option>
                            <option value="To-Do">To-Do</option>
                            <option value="List">List</option>
                        </select>

                    </div>

                    <div class="form-body">
                        <textarea name="content" placeholder="Start writing" required></textarea>
                        <button type="submit" class="done-btn">Done</button>
                    </div>

                </form>
            </div>

            <!-- notes grid -->
            <div class="notes-section">

                <!-- category filter -->
                <div class="category-filter">
                    <span>Filter By:</span>
                    <a href="/notes" class="filter-btn all-filter <%= !category ? 'active' : '' %>">All</a>
                    <a href="/notes?category=Notes" class="filter-btn notes-filter <%= category === 'Notes' ? 'active' : '' %>">Notes</a>
                    <a href="/notes?category=To-Do" class="filter-btn todo-filter <%= category === 'To-Do' ? 'active' : '' %>">To-Do</a>
                    <a href="/notes?category=List" class="filter-btn list-filter <%= category === 'List' ? 'active' : '' %>">List</a>
                </div>

                <% if (notes.length === 0) { %>
                    <p class="empty-state">A clean slate. Start writing!</p>

                <% } else { %>
                    <div class="notes-grid">
                        <% notes.forEach(note => { %>

                            <div class="note-card">
                                <a href="/notes/<%= note.id %>" class="note-card-link">
                                    <div class="note-card-header <%= note.category.toLowerCase().replace('-', '') %>">
                                        <span class="note-title"><%= note.title %></span>
                                        <span class="note-category"><%= note.category %></span>
                                    </div>
                                    <div class="note-card-body">
                                        <span class="note-card-date"><%= note.date %></span>
                                        <p><%= note.content.substring(0, 150) %><%= note.content.length > 150 ? '...' : '' %></p>
                                    </div>
                                </a>
                                <div class="note-card-actions">
                                    <button class="edit-btn" id="<%= note.id %>">Edit</button>
                                    <button class="delete-btn" id="<%= note.id %>">Delete</button>
                                </div>
                            </div>

                        <% }) %>
                    </div>
                <% } %>

            </div>

        </div>

    </main>

<%- include('partials/footer') %>